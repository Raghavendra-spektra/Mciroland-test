{
    "AWSTemplateFormatVersion": "2010-09-09",
    "Description": "this template will deploy network inftrastructure for the ECS FARGATE and EC2 Windows or Linux Instance",
    "Parameters": {
        "CloudLabsDeploymentID": {
            "Description": "DeploymentID Value",
            "Type": "String"
        },
        "AccessKey": {
            "Description": "access key to authenticate to AWS account",
            "Type": "String"
        },
        "SecretKey": {
            "Description": "secret key to authenticate to AWS account",
            "Type": "String"
        },
        "vpcCidr": {
            "Type": "String",
            "Default": "10.10.0.0/16"
        },
        "CheckAcknowledgement": {
            "Type": "String",
            "Default": "TRUE"
        },
        "subnetCidr": {
            "Type": "String",
            "Default": "10.10.0.0/24"
        },
        "clgclusterSubnetCidr": {
            "Type": "String",
            "Default": "10.10.1.0/24"
        },
        "AmazonECSTaskExecutionRolePolicy": {
            "Type": "String",
            "Default": "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy"
        },
        "VMUserName": {
            "Type": "String",
            "Default": "labuser"
        },
        "VMPassword": {
            "Type": "String",
            "Default": "Password.1!!"
        },
        "trainerUserName": {
            "Type": "String",
            "Default": "trainer"
        },
        "trainerUserPassword": {
            "Type": "String",
            "Default": "Password.1!!"
        },
        "ODLID": {
            "Type": "String"
        },
        "ubuntuami": {
            "Type": "String",
            "Default": "ami-05cf1e9f73fbad2e2"
        }
    },
    "Resources": {
        "TaskExecutionRole": {
            "Type": "AWS::IAM::Role",
            "Properties": {
                "AssumeRolePolicyDocument": {
                    "Version": "2012-10-17",
                    "Statement": [
                        {
                            "Effect": "Allow",
                            "Principal": {
                                "Service": [
                                    "ecs-tasks.amazonaws.com"
                                ]
                            },
                            "Action": [
                                "sts:AssumeRole"
                            ]
                        }
                    ]
                },
                "Path": "/",
                "ManagedPolicyArns": [
                    {
                        "Ref": "AmazonECSTaskExecutionRolePolicy"
                    }
                ],
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": {
                            "Fn::Join": [
                                "",
                                [
                                    "TaskExecutionRole-",
                                    {
                                        "Ref": "CloudLabsDeploymentID"
                                    }
                                ]
                            ]
                        }
                    }
                ]
            }
        },
        "clgVpc": {
            "Type": "AWS::EC2::VPC",
            "Properties": {
                "CidrBlock": {
                    "Ref": "vpcCidr"
                },
                "EnableDnsSupport": true,
                "EnableDnsHostnames": true,
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": {
                            "Fn::Join": [
                                "",
                                [
                                    "clgVpc-",
                                    {
                                        "Ref": "CloudLabsDeploymentID"
                                    }
                                ]
                            ]
                        }
                    }
                ]
            }
        },
        "clgInternetGateway": {
            "Type": "AWS::EC2::InternetGateway",
            "Properties": {
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": {
                            "Fn::Join": [
                                "",
                                [
                                    "clgInternetGateway-",
                                    {
                                        "Ref": "CloudLabsDeploymentID"
                                    }
                                ]
                            ]
                        }
                    }
                ]
            }
        },
        "attachInternetGateway": {
            "Type": "AWS::EC2::VPCGatewayAttachment",
            "Properties": {
                "InternetGatewayId": {
                    "Ref": "clgInternetGateway"
                },
                "VpcId": {
                    "Ref": "clgVpc"
                }
            }
        },
        "vmSubnet": {
            "Type": "AWS::EC2::Subnet",
            "Properties": {
                "AvailabilityZone": {
                    "Fn::Sub": "${AWS::Region}a"
                },
                "MapPublicIpOnLaunch": true,
                "VpcId": {
                    "Ref": "clgVpc"
                },
                "CidrBlock": {
                    "Ref": "subnetCidr"
                },
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": {
                            "Fn::Join": [
                                "",
                                [
                                    "vmSubnet-",
                                    {
                                        "Ref": "CloudLabsDeploymentID"
                                    }
                                ]
                            ]
                        }
                    }
                ]
            }
        },
        "clgClusterSubnet": {
            "Type": "AWS::EC2::Subnet",
            "Properties": {
                "MapPublicIpOnLaunch": true,
                "VpcId": {
                    "Ref": "clgVpc"
                },
                "CidrBlock": {
                    "Ref": "clgclusterSubnetCidr"
                },
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": {
                            "Fn::Join": [
                                "",
                                [
                                    "clgClusterSubnet-",
                                    {
                                        "Ref": "CloudLabsDeploymentID"
                                    }
                                ]
                            ]
                        }
                    }
                ]
            }
        },
        "RouteTable": {
            "Type": "AWS::EC2::RouteTable",
            "Properties": {
                "VpcId": {
                    "Ref": "clgVpc"
                },
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": {
                            "Fn::Join": [
                                "",
                                [
                                    "RouteTable-",
                                    {
                                        "Ref": "CloudLabsDeploymentID"
                                    }
                                ]
                            ]
                        }
                    }
                ]
            }
        },
        "routesToInternetGateway": {
            "Type": "AWS::EC2::Route",
            "DependsOn": "attachInternetGateway",
            "Properties": {
                "RouteTableId": {
                    "Ref": "RouteTable"
                },
                "DestinationCidrBlock": "0.0.0.0/0",
                "GatewayId": {
                    "Ref": "clgInternetGateway"
                }
            }
        },
        "vmSubnetRouteTableAssociation": {
            "Type": "AWS::EC2::SubnetRouteTableAssociation",
            "Properties": {
                "SubnetId": {
                    "Ref": "vmSubnet"
                },
                "RouteTableId": {
                    "Ref": "RouteTable"
                }
            }
        },
        "clusterSubnetRouteTableAssociation": {
            "Type": "AWS::EC2::SubnetRouteTableAssociation",
            "Properties": {
                "SubnetId": {
                    "Ref": "clgClusterSubnet"
                },
                "RouteTableId": {
                    "Ref": "RouteTable"
                }
            }
        },
        "vmSecurityGroup": {
            "Type": "AWS::EC2::SecurityGroup",
            "Properties": {
                "GroupDescription": "Allow RDP to client host",
                "VpcId": {
                    "Ref": "clgVpc"
                },
                "SecurityGroupIngress": [
                    {
                        "IpProtocol": "tcp",
                        "FromPort": 22,
                        "ToPort": 22,
                        "CidrIp": "0.0.0.0/0"
                    },
                    {
                        "IpProtocol": "tcp",
                        "FromPort": "0",
                        "ToPort": "65535",
                        "CidrIp": {
                            "Ref": "clgclusterSubnetCidr"
                        }
                    }
                ],
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": {
                            "Fn::Join": [
                                "",
                                [
                                    "vmSecurityGroup-",
                                    {
                                        "Ref": "CloudLabsDeploymentID"
                                    }
                                ]
                            ]
                        }
                    }
                ]
            }
        },
        "clgSg": {
            "Type": "AWS::EC2::SecurityGroup",
            "Properties": {
                "GroupDescription": "this is for container",
                "GroupName": "clgSg",
                "VpcId": {
                    "Ref": "clgVpc"
                },
                "SecurityGroupIngress": [
                    {
                        "FromPort": 443,
                        "ToPort": 443,
                        "IpProtocol": "tcp",
                        "CidrIp": "0.0.0.0/0"
                    },
                    {
                        "FromPort": 443,
                        "ToPort": 443,
                        "IpProtocol": "tcp",
                        "CidrIpv6": "::/0"
                    }
                ],
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": {
                            "Fn::Join": [
                                "",
                                [
                                    "clgSg-",
                                    {
                                        "Ref": "CloudLabsDeploymentID"
                                    }
                                ]
                            ]
                        }
                    }
                ]
            }
        },
        "vmKeyPair": {
            "Type": "AWS::EC2::KeyPair",
            "Properties": {
                "KeyName": {
                    "Fn::Join": [
                        "",
                        [
                            "labkeypair-",
                            {
                                "Ref": "CloudLabsDeploymentID"
                            }
                        ]
                    ]
                }
            }
        },
        "ssmRole": {
            "Type": "AWS::IAM::Role",
            "Properties": {
                "RoleName": {
                "Fn::Join": [
                    "",
                    [
                    "role-assess-ssm-",
                    {
                        "Ref": "CloudLabsDeploymentID"
                    }
                    ]
                ]
                },
                "AssumeRolePolicyDocument": {
                "Version": "2012-10-17",
                "Statement": [
                    {
                    "Effect": "Allow",
                    "Principal": {
                        "Service": "ec2.amazonaws.com"
                    },
                    "Action": "sts:AssumeRole"
                    }
                ]
                },
                "ManagedPolicyArns": [
                "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
                ],
                "Tags": [
                {
                    "Key": "assess",
                    "Value": "true"
                }
                ]
            }
            },
            "ssmInstanceProfile": {
            "Type": "AWS::IAM::InstanceProfile",
            "Properties": {
                "Roles": [
                {
                    "Ref": "ssmRole"
                }
                ]
            }
        },
        "vmInstance": {
            "Type": "AWS::EC2::Instance",
            "Properties": {
                "ImageId": {
                    "Ref":"ubuntuami"
                },
                "InstanceType": "t3.micro",
                "IamInstanceProfile": {
                    "Ref": "ssmInstanceProfile"
                },
                "SecurityGroupIds": [
                    {
                        "Ref": "vmSecurityGroup"
                    }
                ],
                "KeyName": {
                    "Ref": "vmKeyPair"
                },
                "SubnetId": {
                    "Ref": "vmSubnet"
                },
                "UserData": {
                    "Fn::Base64": {
                        "Fn::Sub": "#!/bin/bash\nset -e\nset -x\n\nsed -i 's|^Include /etc/ssh/sshd_config.d/[*].conf|#Include /etc/ssh/sshd_config.d/*.conf|' /etc/ssh/sshd_config\nsed -i 's/^#*PasswordAuthentication no/PasswordAuthentication yes/' /etc/ssh/sshd_config\nsed -i 's/^#*PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config\nsed -i 's/^#*PubkeyAuthentication no/PubkeyAuthentication yes/' /etc/ssh/sshd_config\nsed -i 's/^#*PubkeyAuthentication yes/PubkeyAuthentication yes/' /etc/ssh/sshd_config\nuseradd -m -s /bin/bash ${VMUserName}\necho \"${VMUserName}:${VMPassword}\" | chpasswd\nusermod -aG sudo ${VMUserName}\necho \"${VMUserName} ALL=(ALL) NOPASSWD:ALL\" >> /etc/sudoers.d/${VMUserName}\nchmod 0440 /etc/sudoers.d/${VMUserName}\nsystemctl restart ssh\nsystemctl restart ssh 2>/dev/null || true\necho \"User setup completed at $(date)\" >> /var/log/userdata.log\n"
                    }
                },
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": {
                            "Fn::Join": [
                                "",
                                [
                                    "labvm-",
                                    {
                                        "Ref": "CloudLabsDeploymentID"
                                    }
                                ]
                            ]
                        }
                    }
                ]
            }
        }
    },
    "Outputs": {
        "CloudLabsDeploymentID": {
            "Description": "DeploymentID Value",
            "Value": {
                "Ref": "CloudLabsDeploymentID"
            }
        },
        "VpcId": {
            "Description": "The ID of the VPC",
            "Value": {
                "Ref": "clgVpc"
            }
        },
        "vmSubnetId": {
            "Description": "The ID of the VM Subnet",
            "Value": {
                "Ref": "vmSubnet"
            }
        },
        "vmSecurityGroupId": {
            "Description": "The SG ID of the VM",
            "Value": {
                "Ref": "vmSecurityGroup"
            }
        },
        "clusterSubnetId": {
            "Description": "The ID of the ClusterSubnet",
            "Value": {
                "Ref": "clgClusterSubnet"
            }
        },
        "clusterSecurityGroupId": {
            "Description": "The SG ID of the Cluster",
            "Value": {
                "Ref": "clgSg"
            }
        },
        "TaskExecutionRole": {
            "Description": "The Arn of Role that is utilised by ECS Task Definition",
            "Value": {
                "Fn::GetAtt": [
                    "TaskExecutionRole",
                    "Arn"
                ]
            }
        },
        "VMPublicDNSName": {
            "Description": "public dns name",
            "Value": {
                "Fn::GetAtt": [
                    "vmInstance",
                    "PublicDnsName"
                ]
            }
        },
        "VMPrivateDNSName": {
            "Description": "private dns name",
            "Value": {
                "Fn::GetAtt": [
                    "vmInstance",
                    "PrivateDnsName"
                ]
            }
        },
        "VMUserName": {
            "Description": "VMUserName",
            "Value": {
                "Ref": "VMUserName"
            }
        },
        "VMPassword": {
            "Description": "VMPassword",
            "Value": {
                "Ref": "VMPassword"
            }
        },
        "VMPublicIP": {
            "Description": "VM Public IP",
            "Value": {
                "Fn::GetAtt": [
                    "vmInstance",
                    "PublicIp"
                ]
            }
        },
        "VMPrivateIP": {
            "Description": "VM Private IP",
            "Value": {
                "Fn::GetAtt": [
                    "vmInstance",
                    "PrivateIp"
                ]
            }
        },
        "VMName": {
            "Description": "Name of the VM",
            "Value": {
                "Fn::Join": [
                    "",
                    [
                        "labvm-",
                        {
                            "Ref": "CloudLabsDeploymentID"
                        }
                    ]
                ]
            }
        },
        "SSHCommand": {
            "Value": {
                "Fn::Join": [
                    "",
                    [
                        "ssh ",
                        {
                            "Ref": "VMUserName" 
                        },
                        "@",
                        {
                            "Fn::GetAtt": [
                                "vmInstance",
                                "PublicDnsName"
                            ]
                        }
                    ]
                ]
            }
        }
    }
}